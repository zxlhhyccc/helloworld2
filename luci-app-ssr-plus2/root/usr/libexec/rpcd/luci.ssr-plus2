-- uci
local ucic = uci.cursor()
-- 字符串去除空格
string.trim = util.trim


-- 包名
local PACKAGE_NAME = 'ssr-plus2'
-- 加载配置
ucic:load(PACKAGE_NAME)


-- 计算 md5 值
local function md5_string(data)
    -- 生成临时文件名
    -- os.time 保证每秒唯一，但不足以避免全部冲突；math.random(1000,9999) 增加文件名唯一性，避免并发时冲突
    local tmp = "/tmp/md5_tmp_" .. os.time() .. "_" .. math.random(1000,9999)
     -- 写入临时文件
    fs.writefile(tmp, data)
    
    -- 执行 md5sum 命令
    local md5 = sys.exec(string.format('md5sum "%s" 2>/dev/null | cut -d " " -f1', tmp)):gsub("%s+", "")
    
     -- 删除临时文件
    nixio.fs.remove(tmp)

    -- 返回 md5值
    return md5
end

-- base64 解码
local bc = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/'
local function base64Decode(data)
    data = string.gsub(data, '[^' .. bc .. '=]', '')
    return (data:gsub('.', function(x)
        if (x == '=') then
            return ''
        end
        local r, f = '', (bc:find(x) - 1)
        for i = 6, 1, -1 do
            r = r .. (f % 2 ^ i - f % 2 ^ (i - 1) > 0 and '1' or '0')
        end
        return r;
    end):gsub('%d%d%d?%d?%d?%d?%d?%d?', function(x)
        if (#x ~= 8) then
            return ''
        end
        local c = 0
        for i = 1, 8 do
            c = c + (x:sub(i, i) == '1' and 2 ^ (8 - i) or 0)
        end
        return string.char(c)
    end))
end

-- 是否 base64 数据
local function is_valid_base64(data)
    -- 去除换行
    local tempText = string.gsub(data, '\n', '')
    -- 判断
    return #tempText % 4 == 0 and tempText:match("^[A-Za-z0-9+/=]+$")
end

-- base64 解码(判断是否需要解码)
local function base64DecodeIfNeed(text)
    local raw = text
    if not text then
        return ''
    end


    if is_valid_base64(text) then
        -- base64 编码数据
        local result = base64Decode(text)
        if result then
            return result:gsub("%z", "")
        else
            return raw
        end
    else
        -- 非 base64 编码数据
        return raw
    end
end

-- curl
local function curl(url)
    -- 清理 URL 中的隐藏字符
    url = url:gsub("%s+$", ""):gsub("^%s+", ""):gsub("%z", "")

    -- 构建curl命令（确保 user_agent 为空时不添加 -A 参数）
    local cmd = string.format(
        'sh /usr/share/ssr-plus2/curl.sh "%s"',
        url:gsub('["$`\\]', '\\%0')  -- 安全转义
    )
    
    -- 执行
    local stdout = sys.exec(cmd)
    -- 去除空格
    stdout = util.trim(stdout)

    -- 计算 md5
    local md5 = md5_string(stdout)
    -- 返回
    return stdout, md5
end


-- 自定义函数
function table.contains(t, val)
    for _, v in ipairs(t) do
        if v == val then
            return true
        end
    end
    return false
end

local methods = {
    updateAdvancedAddress = {
        -- 参数说明
        args = {cfgid = "a_string"},
        
