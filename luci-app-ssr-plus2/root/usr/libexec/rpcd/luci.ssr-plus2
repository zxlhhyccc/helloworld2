        call = function(args)
            -- 打印 参数
            -- print(json.stringify(args))
            -- 取出参数
            local cfgid = args.cfgid
            
            -- 文件路径
            local savePath = '/etc/ssr-plus2/advance-address/'


            -- 新建文件夹 防止文件夹不存在
            fs.mkdirr(savePath)
            
            -- 更新的文件名称
            local updateFileName = {}
            -- 结果
            local updateResult = {}
            
            
            -- 不为空
            local isNotEmpty = string.len(cfgid) ~= 0
                
            
            -- 获取 所有域名列表
            ucic:foreach(PACKAGE_NAME, "advanced_address", function(section)
                -- name
                local name = section['.name']
                -- 别名
                local alias = section['alias']
                -- 地址
                local address = section['address']
                -- 地址 MD5
                local md5String = md5_string(address)
                -- 状态
                local status
                -- 描述
                local message


                if isNotEmpty and cfgid ~= name then
                    -- 不为空 且 不是指定的
                    -- 继续下一个
                    return
                end
                
                
                
                -- 调用 curl
                local raw, new_md5 = curl(address)
                
                
                -- 文件名称
                local saveFile = savePath .. md5String
                
                -- 保存
                table.insert(updateFileName, md5String)
                
                
                
                if #raw > 0 then
                    -- 有数据
                    -- 解码
                    local decode = base64DecodeIfNeed(raw)
                    
                    if #decode > 0 then
                        -- 先删除
                        -- fs.remove(saveFile)
                        
                        -- 写入文件 添加 最后一个换行 解决shell 读取问题
                        fs.writefile(saveFile, decode .. "\n")
                        
                        -- 删除注释
                        -- local comment_pattern = "^[!\\[@]+"
                                               

                        -- 删除 [ 或 ! 或 @ 或 . 或 / 开头数据
                        -- 删除空格
                        -- 替换 | 替换为空
                        -- sed "/^[\[!@\.\/]/d; /^$/d; s/[|]*//g" 286cf0932c3c632d9e229d561e103f1e
                        
                        sys.exec(string.format("sed -i '/^[\[!@\.\/]/d; /^$/d; s/[|]*//g' %s", saveFile))
                       
                        
                        status = 0
                        message = "成功"
                        
                        -- 设置更新时间
                        ucic:set(PACKAGE_NAME, name, 'update_time', os.date("%Y-%m-%d %H:%M:%S"))
                    else
                        status = 1
                        message = "base64解码失败"
                    end
                    
                else
                    status = 1
                    message = "下载失败"
                end
                
                
                -- 结果
                local result  = {
                    alias     = alias,
                    address   = address,
                    md5String = md5String,
                    status    = status,
                    message   = message
                }
                
                -- 保存结果
                table.insert(updateResult, result)
            end)


            -- 提交修改
            ucic:commit(PACKAGE_NAME)
            

            if isNotEmpty == false then
                -- 全部 更新才需要清理
                -- 列出 存在 的 文件
                local existFileIterate = fs.dir(savePath)
                
                -- 循环
                for existFileName in existFileIterate
                do
                    -- print('existFileName:' .. existFileName)
                    if table.contains(updateFileName, existFileName) == false then
                        -- 文件不在 列表中 需要删除
                        -- print('existFileName:' .. existFileName)
                        fs.remove(savePath .. existFileName)
                    end
                end
            end




            -- 返回结果 只能是JsonObject
            local returnData = {
                result = updateResult
            }
            
            -- 返回
           return returnData, 0
        end
    },
    
    -- latency = {
